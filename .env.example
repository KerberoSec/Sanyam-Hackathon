FLASK_ENV=development
FLASK_APP=app.py
DEBUG=True

# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost/habit_tracker

# JWT Configuration
JWT_SECRET_KEY=change-this-in-production-with-a-secure-key

# Flask Configuration
SECRET_KEY=change-this-in-production-with-a-secure-key

# Optional: Email Configuration (for reminders)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Frontend
FRONTEND_URL=http://localhost:5000

# Gemini API Configuration (for AI Coaching)
# Get your API key from https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key-here
